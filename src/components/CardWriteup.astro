---
interface Props {
  title: string;
  ctf: string;
  category: string;
  summary: string;
  difficulty: 'Beginner' | 'Intermediate' | 'Advanced' | 'Critical';
  points?: number;
  readTime: string;
  solved?: boolean;
  href?: string;
}

const { title, ctf, category, summary, difficulty, points, readTime, solved = true, href } = Astro.props;

const difficultyStyles: Record<string, string> = {
  Beginner: 'bg-rh-accent-soft text-rh-accent',
  Intermediate: 'bg-amber-100 text-amber-800',
  Advanced: 'bg-orange-100 text-orange-800',
  Critical: 'bg-red-100 text-rh-professional',
};

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class="group flex flex-col gap-3 rounded-lg border border-rh-border bg-rh-surface p-5 transition-shadow hover:shadow-md"
>
  <!-- Tag combinada CTF/Categoria + Dificuldade -->
  <div class="flex items-center justify-between gap-2">
    <span class="font-mono-code text-xs uppercase tracking-wide text-rh-muted">{ctf} / {category}</span>
    <span class={`rounded-full px-2.5 py-0.5 text-xs font-medium ${difficultyStyles[difficulty]}`}>
      {difficulty}
    </span>
  </div>

  <h3 class="text-lg font-semibold leading-snug text-rh-text group-hover:text-rh-accent">
    {title}
  </h3>

  <p class="text-sm leading-relaxed text-rh-muted">{summary}</p>

  <div class="mt-auto flex items-center justify-between pt-2">
    <div class="flex items-center gap-2 text-xs text-rh-muted">
      {!solved && (
        <span class="rounded border border-rh-professional/40 px-1.5 py-0.5 text-rh-professional">não resolvido</span>
      )}
      {points && <span class="font-mono-code">{points} pts</span>}
    </div>
    <span class="whitespace-nowrap text-xs text-rh-muted">{readTime}</span>
  </div>
</Tag>
