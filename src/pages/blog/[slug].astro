---
import { getCollection, render } from 'astro:content';
import LayoutRH from '../../layouts/LayoutRH.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<LayoutRH title={`${post.data.title} — Lucas Carvalho`} description={post.data.summary}>
  <div class="mx-auto max-w-3xl px-4 py-16 md:px-8">
    <a href="/#blog" class="text-sm text-rh-accent hover:underline">← voltar ao blog</a>

    <div class="mt-4 flex items-center gap-3">
      <span class="rounded-full bg-rh-accent-soft px-2.5 py-0.5 text-xs font-medium text-rh-accent">
        {post.data.difficulty}
      </span>
    </div>

    <h1 class="mt-3 text-3xl font-bold text-rh-text">{post.data.title}</h1>
    <p class="mt-2 text-rh-muted">{post.data.summary}</p>

    <div class="mt-4 flex flex-wrap items-center gap-2 text-xs text-rh-muted">
      <span>{post.data.date.toLocaleDateString('pt-BR')}</span>
      <span>·</span>
      <span>{post.data.readTime} de leitura</span>
      <span>·</span>
      <div class="flex gap-1.5">
        {post.data.tags.map((tag: string) => (
          <span class="rounded border border-rh-border bg-rh-bg px-2 py-0.5 font-mono-code">{tag}</span>
        ))}
      </div>
    </div>

    <article class="prose prose-neutral mt-10 max-w-none prose-headings:font-semibold prose-a:text-rh-accent">
      <Content />
    </article>
  </div>
</LayoutRH>
