---
import { getCollection, render } from 'astro:content';
import LayoutRH from '../../layouts/LayoutRH.astro';

export async function getStaticPaths() {
  const writeups = await getCollection('writeups');
  return writeups.map((writeup) => ({
    params: { slug: writeup.id },
    props: { writeup },
  }));
}

const { writeup } = Astro.props;
const { Content } = await render(writeup);
---

<LayoutRH title={`${writeup.data.title} — Lucas Carvalho`} description={writeup.data.summary}>
  <div class="mx-auto max-w-3xl px-4 py-16 md:px-8">
    <a href="/#writeups" class="text-sm text-rh-accent hover:underline">← voltar aos write-ups</a>

    <div class="mt-4 flex items-center gap-3">
      <span class="font-mono-code text-xs uppercase tracking-wide text-rh-muted">
        {writeup.data.ctf} / {writeup.data.category}
      </span>
      <span class="rounded-full bg-rh-accent-soft px-2.5 py-0.5 text-xs font-medium text-rh-accent">
        {writeup.data.difficulty}
      </span>
      {!writeup.data.solved && (
        <span class="rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-rh-professional">
          Não resolvido
        </span>
      )}
    </div>

    <h1 class="mt-3 text-3xl font-bold text-rh-text">{writeup.data.title}</h1>
    <p class="mt-2 text-rh-muted">{writeup.data.summary}</p>

    <div class="mt-4 flex flex-wrap items-center gap-2 text-xs text-rh-muted">
      <span>{writeup.data.date.toLocaleDateString('pt-BR')}</span>
      <span>·</span>
      <span>{writeup.data.readTime} de leitura</span>
      {writeup.data.points && (
        <>
          <span>·</span>
          <span>{writeup.data.points} pts</span>
        </>
      )}
      <span>·</span>
      <div class="flex gap-1.5">
        {writeup.data.tags.map((tag: string) => (
          <span class="rounded border border-rh-border bg-rh-bg px-2 py-0.5 font-mono-code">{tag}</span>
        ))}
      </div>
    </div>

    <article class="prose prose-neutral mt-10 max-w-none prose-headings:font-semibold prose-a:text-rh-accent">
      <Content />
    </article>
  </div>
</LayoutRH>
